# Environment Variables Template
# Copy this to .env and fill in your actual values

# Anthropic API Key (Required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Keys (For payment processing)
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# File Upload Settings
MAX_FILE_SIZE=5242880  # 5MB in bytes
UPLOAD_FOLDER=uploads

# CORS Settings (Update with your frontend URL in production)
ALLOWED_ORIGINS=http://localhost:8000,https://yourfrontend.com

# Database (SQLite by default)
DATABASE_PATH=resume_analyzer.db

# Optional: Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Optional: Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Optional: Sentry for error tracking
SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxx
